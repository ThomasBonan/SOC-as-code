# SOC-as-code — Variables d'environnement requises
# Copier vers /etc/soc-as-code/.env et sourcer avant d'exécuter les playbooks :
#   set -a; source /etc/soc-as-code/.env; set +a

# Chemin vers le kubeconfig du cluster
KUBECONFIG=/home/mgmt-user/SOC-as-code/ansible/playbooks/artifacts/admin.conf

# Environnement cible : dev | staging | prod
SOC_ENV=dev
