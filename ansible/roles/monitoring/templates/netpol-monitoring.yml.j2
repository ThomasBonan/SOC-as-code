# netpol-monitoring.yml.j2 — NetworkPolicies pour soc-monitoring
#
# Règles :
#   1. Prometheus → pods SOC (scrape métriques)
#   2. Prometheus → node-exporter (9100)
#   3. blackbox-exporter → services SOC (probes HTTP)
#   4. Grafana → Prometheus (9090)
#   5. Grafana → Loki (3100)
#   6. Grafana → Wazuh OpenSearch (9200)
#   7. Ingress → Grafana (3000)
#   8. DNS egress pour soc-monitoring
---
# Règle 1 : Prometheus peut scraper n'importe quel pod SOC
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-prometheus-scrape
  namespace: "{{ monitoring_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: prometheus
  policyTypes:
    - Egress
  egress:
    # Scrape metrics ports dans les namespaces SOC
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.wazuh }}"
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.thehive }}"
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.cortex }}"
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.misp }}"
      ports:
        - protocol: TCP
          port: 9187   # postgres_exporter
        - protocol: TCP
          port: 9104   # mysqld_exporter
        - protocol: TCP
          port: 9121   # redis_exporter
    # Scrape Cilium agents (kube-system)
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: TCP
          port: {{ monitoring_cilium_agent_port }}
        - protocol: TCP
          port: {{ monitoring_cilium_operator_port }}
---
# Règle 2 : Grafana → Prometheus
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-grafana-prometheus
  namespace: "{{ monitoring_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: grafana
  policyTypes:
    - Egress
  egress:
    - to:
        - podSelector:
            matchLabels:
              app.kubernetes.io/name: prometheus
      ports:
        - protocol: TCP
          port: 9090
    # Loki
    - to:
        - podSelector:
            matchLabels:
              app: loki
      ports:
        - protocol: TCP
          port: 3100
    # Wazuh OpenSearch
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.wazuh }}"
      ports:
        - protocol: TCP
          port: 9200
---
# Règle 3 : Ingress → Grafana
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: ingress-from-nginx-grafana
  namespace: "{{ monitoring_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: grafana
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: ingress-nginx
      ports:
        - protocol: TCP
          port: 3000
---
# Règle 4 : Blackbox → services SOC (probes HTTP)
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-blackbox-soc-probes
  namespace: "{{ monitoring_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: prometheus-blackbox-exporter
  policyTypes:
    - Egress
  egress:
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.thehive }}"
      ports:
        - protocol: TCP
          port: 9000
        - protocol: TCP
          port: 8080
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.cortex }}"
      ports:
        - protocol: TCP
          port: 9001
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.misp }}"
      ports:
        - protocol: TCP
          port: 443
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_namespaces.wazuh }}"
      ports:
        - protocol: TCP
          port: 55000
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: soc-shuffle
      ports:
        - protocol: TCP
          port: 5001
---
# Règle 5 : DNS egress pour soc-monitoring
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-dns
  namespace: "{{ monitoring_namespace }}"
spec:
  podSelector: {}
  policyTypes:
    - Egress
  egress:
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53
