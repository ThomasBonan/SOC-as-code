{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Métriques réseau Cilium — flux, drops, NetworkPolicy violations, DNS",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "title": "Flux réseau Hubble (par namespace)",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (source_namespace)(rate(hubble_flows_processed_total{source_namespace=~\"soc-.*\"}[5m]))", "legendFormat": "{{ source_namespace }}"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "color": {"fixedColor": "red", "mode": "fixed"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "title": "Paquets droppés (policy denied)",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (reason)(rate(hubble_drop_total[5m]))", "legendFormat": "{{ reason }}"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {"frameIndex": 0, "showHeader": true},
      "title": "NetworkPolicy violations (Cilium)",
      "type": "table",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (source_namespace, source, destination_namespace, destination)(increase(cilium_policy_verdict{verdict=\"denied\"}[5m])) > 0", "legendFormat": "", "instant": true}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "title": "DNS queries par service",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (source_namespace)(rate(hubble_dns_queries_total{source_namespace=~\"soc-.*\"}[5m]))", "legendFormat": "{{ source_namespace }}"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["network", "cilium", "infrastructure", "soc"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "Europe/Paris",
  "title": "Infra — Réseau Cilium",
  "uid": "infra-network",
  "version": 1
}
