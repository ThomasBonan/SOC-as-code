{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Pipeline SOC E2E — MTTD, latences, débits, uptime",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.95}, {"color": "green", "value": 0.99}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Uptime services SOC (30 jours)",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg_over_time(probe_success{job=~\".*blackbox.*\"}[30d]) * 100", "legendFormat": "{{ instance }}"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 2,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "title": "Latence probes HTTP (ms)",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_duration_seconds{job=~\".*blackbox.*\"} * 1000", "legendFormat": "{{ instance }}"}]
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "unit": "ms"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 3,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "title": "Latence pipeline Wazuh → Risk Engine (ms)",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "loki", "uid": "loki"}, "expr": "{namespace=\"soc-thehive\", app=\"risk-engine\"} | logfmt | unwrap duration_ms [5m]", "legendFormat": "Risk Engine latency"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}}, "overrides": []},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 4,
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "title": "Pods Running par namespace SOC",
      "type": "timeseries",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (namespace)(kube_pod_status_phase{namespace=~\"soc-.*\",phase=\"Running\"})", "legendFormat": "{{ namespace }}"}]
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 20},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "title": "Erreurs pipeline (1h)",
      "type": "stat",
      "targets": [{"datasource": {"type": "loki", "uid": "loki"}, "expr": "sum(count_over_time({namespace=~\"soc-.*\"} |= \"ERROR\" [1h]))", "legendFormat": "Erreurs"}]
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 20},
      "id": 6,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "title": "Intégrations Wazuh→TheHive (1h)",
      "type": "stat",
      "targets": [{"datasource": {"type": "loki", "uid": "loki"}, "expr": "sum(count_over_time({namespace=\"soc-wazuh\"} |= \"custom-thehive\" [1h]))", "legendFormat": "Intégrations"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ssi", "pipeline", "e2e", "soc"],
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "Europe/Paris",
  "title": "SSI — Pipeline E2E",
  "uid": "ssi-pipeline",
  "version": 1
}
