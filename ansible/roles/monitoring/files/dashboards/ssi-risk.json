      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "loki", "uid": "loki"}, "expr": "sum(count_over_time({namespace=\"soc-thehive\", app=\"risk-engine\"} |= \"decision=escalated\" [5m]))", "legendFormat": "escalated"},
        {"datasource": {"type": "loki", "uid": "loki"}, "expr": "sum(count_over_time({namespace=\"soc-thehive\", app=\"risk-engine\"} |= \"decision=auto_contain\" [5m]))", "legendFormat": "auto_contain"},
        {"datasource": {"type": "loki", "uid": "loki"}, "expr": "sum(count_over_time({namespace=\"soc-thehive\", app=\"risk-engine\"} |= \"decision=auto_promote\" [5m]))", "legendFormat": "auto_promote"},
        {"datasource": {"type": "loki", "uid": "loki"}, "expr": "sum(count_over_time({namespace=\"soc-thehive\", app=\"risk-engine\"} |= \"decision=auto_close\" [5m]))", "legendFormat": "auto_close"},
        {"datasource": {"type": "loki", "uid": "loki"}, "expr": "sum(count_over_time({namespace=\"soc-thehive\", app=\"risk-engine\"} |= \"decision=reviewed\" [5m]))", "legendFormat": "reviewed"}
