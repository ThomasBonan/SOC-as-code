      "title": "Logs Risk Engine — Escalades critiques",
      "type": "logs",
      "targets": [{"datasource": {"type": "loki", "uid": "loki"}, "expr": "{namespace=\"soc-thehive\", app=\"risk-engine\"} |= \"decision=escalated\" | logfmt | score > 90", "legendFormat": ""}]
