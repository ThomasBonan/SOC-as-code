        },
        {
          "name": "body",
          "value": "{\"Event\":{\"info\":\"[SOC] $exec.all_fields.rule.description\",\"distribution\":0,\"threat_level_id\":2,\"analysis\":1,\"Attribute\":[{\"type\":\"ip-dst\",\"value\":\"$exec.all_fields.data.srcip\",\"category\":\"Network activity\",\"to_ids\":true,\"comment\":\"Case: $action_promote_to_case.body._id | Score: $action_call_risk_engine.body.risk_score\"}]}}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 1600,
        "y": -150
      }
