        {
          "name": "body",
          "value": "{\"category\":\"SOC-Automation\",\"title\":\"Pipeline Report\",\"content\":\"Risk Score: $action_call_risk_engine.body.risk_score | Decision: $action_call_risk_engine.body.risk_decision | Cortex status: $action_get_cortex_result.body.status | MISP matches: $action_search_misp.body.response.Attribute\"}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 1800,
        "y": -150
      }
