{
  "name": "SOC Alert Triage",
  "description": "Wazuh -> TheHive alert -> Cortex -> MISP -> Risk Engine -> AR/Escalate | HTTP-only pipeline",
  "start": "action_create_thehive_alert",
  "tags": [
    "soc",
    "triage",
    "wazuh",
    "thehive",
    "cortex",
    "misp"
  ],
  "triggers": [
    {
      "trigger_type": "WEBHOOK",
      "id": "trigger_wazuh_webhook",
      "name": "Wazuh Alert Webhook",
      "status": "running",
      "parameters": [
        {
          "name": "info",
          "value": "Webhook declenche par Wazuh via ossec.conf integration"
        }
      ],
      "position": {
        "x": -600,
        "y": 0
      }
    }
  ],
  "actions": [
    {
      "id": "action_create_thehive_alert",
      "label": "action_create_thehive_alert",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "POST",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_THEHIVE_URL/api/v1/alert"
        },
        {
          "name": "method",
          "value": "POST"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_THEHIVE_APIKEY\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"title\":\"[Wazuh] $exec.all_fields.rule.description\",\"type\":\"External\",\"source\":\"wazuh\",\"sourceRef\":\"wazuh-$exec.all_fields.agent.id-$exec.all_fields.rule.id-$exec.all_fields.timestamp\",\"description\":\"Agent: $exec.all_fields.agent.name ($exec.all_fields.agent.ip) | Rule: $exec.all_fields.rule.id | Level: $exec.all_fields.rule.level\",\"severity\":2,\"tags\":[\"source:wazuh\",\"agent:$exec.all_fields.agent.name\",\"rule:$exec.all_fields.rule.id\"]}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": -400,
        "y": 0
      }
    },
    {
      "id": "action_run_cortex_analysis",
      "label": "action_run_cortex_analysis",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "POST",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_CORTEX_URL/api/analyzer/$ENV_CORTEX_ANALYZER/run"
        },
        {
          "name": "method",
          "value": "POST"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_CORTEX_APIKEY\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"data\":\"$exec.all_fields.data.srcip\",\"dataType\":\"ip\",\"message\":\"SOC Triage - Alert $action_create_thehive_alert.body._id\",\"tlp\":2,\"parameters\":{}}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": -200,
        "y": 0
      }
    },
    {
      "id": "action_get_cortex_result",
      "label": "action_get_cortex_result",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "GET",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_CORTEX_URL/api/job/$action_run_cortex_analysis.body.id/waitreport?atMost=5minutes"
        },
        {
          "name": "method",
          "value": "GET"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_CORTEX_APIKEY\"}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "action_search_misp",
      "label": "action_search_misp",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "POST",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_MISP_URL/attributes/restSearch"
        },
        {
          "name": "method",
          "value": "POST"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"$ENV_MISP_APIKEY\",\"Accept\":\"application/json\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"value\":\"$exec.all_fields.data.srcip\",\"type\":\"ip-src\",\"limit\":10,\"returnFormat\":\"json\"}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 200,
        "y": 0
      }
    },
    {
      "id": "action_call_risk_engine",
      "label": "action_call_risk_engine",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "POST",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_RISK_ENGINE_URL/score"
        },
        {
          "name": "method",
          "value": "POST"
        },
        {
          "name": "headers",
          "value": "{\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"wazuh_severity\":\"$exec.all_fields.rule.level\",\"cortex_max_level\":0,\"misp_hit\":false,\"asset_type\":\"default\",\"frequency\":1,\"case_id\":\"$action_create_thehive_alert.body._id\",\"environment\":\"$ENV_SOC_ENVIRONMENT\"}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 400,
        "y": 0
      }
    },
    {
      "id": "action_ignore_alert",
      "label": "action_ignore_alert",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "PATCH",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_THEHIVE_URL/api/v1/alert/$action_create_thehive_alert.body._id"
        },
        {
          "name": "method",
          "value": "PATCH"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_THEHIVE_APIKEY\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"status\":\"Ignored\",\"tags\":[\"soc:auto_closed\",\"risk_score:$action_call_risk_engine.body.risk_score\"]}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 600,
        "y": 300
      }
    },
    {
      "id": "action_promote_to_case",
      "label": "action_promote_to_case",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "POST",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_THEHIVE_URL/api/v1/alert/$action_create_thehive_alert.body._id/case"
        },
        {
          "name": "method",
          "value": "POST"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_THEHIVE_APIKEY\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"observablerule\":\"all\",\"taskrule\":\"all\"}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 600,
        "y": -150
      }
    },
    {
      "id": "action_add_case_observable",
      "label": "action_add_case_observable",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "POST",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_THEHIVE_URL/api/v1/case/$action_promote_to_case.body._id/observable"
        },
        {
          "name": "method",
          "value": "POST"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_THEHIVE_APIKEY\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"data\":\"$exec.all_fields.data.srcip\",\"dataType\":\"ip\",\"message\":\"Source IP from Wazuh alert\",\"tlp\":2,\"pap\":2,\"tags\":[\"source:wazuh\"]}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 800,
        "y": -150
      }
    },
    {
      "id": "action_update_case_risk",
      "label": "action_update_case_risk",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "PATCH",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_THEHIVE_URL/api/v1/case/$action_promote_to_case.body._id"
        },
        {
          "name": "method",
          "value": "PATCH"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_THEHIVE_APIKEY\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"tags\":[\"source:wazuh\",\"risk_engine:processed\",\"risk_decision:$action_call_risk_engine.body.risk_decision\"],\"customFields\":{\"risk_score_v2\":{\"float\":$action_call_risk_engine.body.risk_score},\"risk_decision\":{\"string\":\"$action_call_risk_engine.body.risk_decision\"}}}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 1000,
        "y": -150
      }
    },
    {
      "id": "action_auto_promote",
      "label": "action_auto_promote",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "PATCH",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_THEHIVE_URL/api/v1/case/$action_promote_to_case.body._id"
