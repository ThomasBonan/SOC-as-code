        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_THEHIVE_APIKEY\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"severity\":4,\"tags\":[\"soc:escalated\",\"priority:critical\"]}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 1200,
        "y": 50
      }
