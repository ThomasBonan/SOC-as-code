          "value": "PATCH"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $ENV_THEHIVE_APIKEY\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"severity\":3,\"tags\":[\"soc:auto_promoted\"]}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 1200,
        "y": -300
      }
    },
    {
      "id": "action_get_wazuh_jwt",
      "label": "action_get_wazuh_jwt",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "POST",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_WAZUH_API_URL/security/user/authenticate"
        },
        {
          "name": "method",
          "value": "POST"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Basic $ENV_WAZUH_B64AUTH\"}"
        },
        {
          "name": "body",
          "value": ""
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 1200,
        "y": -100
      }
    },
    {
      "id": "action_active_response",
      "label": "action_active_response",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "PUT",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_WAZUH_API_URL/active-response?agents_list=$exec.all_fields.agent.id"
        },
        {
          "name": "method",
          "value": "PUT"
        },
        {
          "name": "headers",
          "value": "{\"Authorization\":\"Bearer $action_get_wazuh_jwt.body.data.token\",\"Content-Type\":\"application/json\"}"
        },
        {
          "name": "body",
          "value": "{\"command\":\"firewall-drop\",\"arguments\":[\"-\",\"null\",\"$exec.all_fields.data.srcip\",\"600\"]}"
        },
        {
          "name": "ssl_verify",
          "value": "false"
        }
      ],
      "position": {
        "x": 1400,
        "y": -100
      }
    },
    {
      "id": "action_escalate",
      "label": "action_escalate",
      "app_name": "http",
      "app_version": "1.4.0",
      "name": "PATCH",
      "parameters": [
        {
          "name": "url",
          "value": "$ENV_THEHIVE_URL/api/v1/case/$action_promote_to_case.body._id"
