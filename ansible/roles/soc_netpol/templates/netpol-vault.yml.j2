# netpol-vault.yml.j2 — NetworkPolicies pour le namespace soc-vault
#
# Règles :
#   1. ESO → Vault (8200/TCP) : synchronisation des secrets
#   2. Vault → K8s API (443/TCP) : token review pour Kubernetes auth
#   3. Ingress → Vault UI (8200/TCP) : accès optionnel à l'UI
#   4. Controller Ansible → Vault (8200/TCP) : AppRole auth
---
# Règle 1 : ESO → Vault (ingress dans soc-vault depuis pods ESO)
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: ingress-from-eso
  namespace: "{{ soc_netpol_vault_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: vault
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_netpol_vault_namespace }}"
          podSelector:
            matchLabels:
              app.kubernetes.io/name: external-secrets
      ports:
        - protocol: TCP
          port: 8200
---
# Règle 2 : Ingress-nginx → Vault UI
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: ingress-from-nginx
  namespace: "{{ soc_netpol_vault_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: vault
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: ingress-nginx
      ports:
        - protocol: TCP
          port: 8200
---
# Règle 3 : Controller Ansible (ipBlock) → Vault API
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: ingress-from-controller
  namespace: "{{ soc_netpol_vault_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: vault
  policyTypes:
    - Ingress
  ingress:
    - from:
{% for cidr in soc_allowed_api_sources %}
        - ipBlock:
            cidr: "{{ cidr }}"
{% endfor %}
      ports:
        - protocol: TCP
          port: 8200
---
# Règle 4 : Vault → K8s API server (egress pour token review)
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-k8s-api
  namespace: "{{ soc_netpol_vault_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: vault
  policyTypes:
    - Egress
  egress:
    - ports:
        - protocol: TCP
          port: 443
        - protocol: TCP
          port: 6443
---
# Règle 5 : DNS egress pour Vault
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-dns
  namespace: "{{ soc_netpol_vault_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: vault
  policyTypes:
    - Egress
  egress:
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53
