# netpol-argocd.yml.j2 — NetworkPolicies pour le namespace argocd
#
# Règles :
#   1. Ingress-nginx → argocd-server (port 8080) — accès UI/API
#   2. ArgoCD → K8s API (6443) — reconciliation et apply des manifests
#   3. ArgoCD repo-server → Git egress (443/22) — fetch des repos
#   4. Intra-namespace ArgoCD (server ↔ redis, controller ↔ redis, etc.)
#   5. Prometheus scrape (ingress depuis soc-monitoring)
#   6. DNS egress pour argocd
---
# Règle 1 : Ingress-nginx → argocd-server (UI/API)
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: ingress-from-nginx-argocd
  namespace: "{{ soc_netpol_argocd_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: argocd-server
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: ingress-nginx
      ports:
        - protocol: TCP
          port: 8080
---
# Règle 2 : ArgoCD (server + controller) → K8s API
# Nécessaire pour appliquer les manifests sur le cluster
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-argocd-k8s-api
  namespace: "{{ soc_netpol_argocd_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/part-of: argocd
  policyTypes:
    - Egress
  egress:
    # K8s API server
    - ports:
        - protocol: TCP
          port: 6443
        - protocol: TCP
          port: 443
---
# Règle 3 : argocd-repo-server → Git (clone/fetch)
# Port 443 pour HTTPS, 22 pour SSH
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-argocd-repo-git
  namespace: "{{ soc_netpol_argocd_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: argocd-repo-server
  policyTypes:
    - Egress
  egress:
    - ports:
        - protocol: TCP
          port: 443
        - protocol: TCP
          port: 22
---
# Règle 4 : Trafic intra-namespace ArgoCD
# Permet la communication server ↔ redis, controller ↔ redis, server ↔ repo-server
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-argocd-internal
  namespace: "{{ soc_netpol_argocd_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/part-of: argocd
  policyTypes:
    - Ingress
    - Egress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_netpol_argocd_namespace }}"
          podSelector:
            matchLabels:
              app.kubernetes.io/part-of: argocd
  egress:
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_netpol_argocd_namespace }}"
          podSelector:
            matchLabels:
              app.kubernetes.io/part-of: argocd
---
# Règle 5 : Prometheus → ArgoCD (scrape métriques)
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: ingress-prometheus-argocd-metrics
  namespace: "{{ soc_netpol_argocd_namespace }}"
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/part-of: argocd
  policyTypes:
    - Ingress
  ingress:
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ soc_netpol_monitoring_namespace }}"
          podSelector:
            matchLabels:
              app.kubernetes.io/name: prometheus
      ports:
        - protocol: TCP
          port: "{{ soc_netpol_argocd_metrics_port }}"
        - protocol: TCP
          port: "{{ soc_netpol_argocd_controller_metrics_port }}"
        - protocol: TCP
          port: "{{ soc_netpol_argocd_repo_metrics_port }}"
        - protocol: TCP
          port: 8080   # health probe blackbox
---
# Règle 6 : DNS egress pour le namespace argocd
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: egress-dns-argocd
  namespace: "{{ soc_netpol_argocd_namespace }}"
spec:
  podSelector: {}
  policyTypes:
    - Egress
  egress:
    - to:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: kube-system
      ports:
        - protocol: UDP
          port: 53
        - protocol: TCP
          port: 53
