apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: "{{ netpol_name }}"
  namespace: "{{ netpol_namespace }}"
  labels:
{% for label_key, label_val in netpol_labels.items() %}
    {{ label_key }}: "{{ label_val }}"
{% endfor %}
  annotations:
    soc.lab/managed-by: "soc_foundations"
    soc.lab/policy-type: "api-ingress"
    soc.lab/allowed-sources: "{{ netpol_allowed_cidrs | join(', ') }}"
spec:
  podSelector: {{ netpol_pod_selector | to_json }}
  policyTypes:
    - Ingress
  ingress:
    # Règle 1 : accès API depuis les sources IP autorisées (soc_allowed_api_sources)
    - from:
{% for cidr in netpol_allowed_cidrs %}
        - ipBlock:
            cidr: "{{ cidr }}"
{% endfor %}
      ports:
        - protocol: TCP
          port: {{ netpol_api_port }}
{% if netpol_allow_ingress_controller | default(true) %}
    # Règle 2 : accès depuis le contrôleur Ingress (nginx) pour le routage Ingress-based
    # Nécessaire car nginx utilise des IPs de nœuds (hors soc_allowed_api_sources)
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ netpol_ingress_controller_namespace }}"
          podSelector:
            matchLabels: {{ netpol_ingress_controller_pod_labels | to_json }}
      ports:
        - protocol: TCP
          port: {{ netpol_api_port }}
{% endif %}
{% for ns in netpol_allow_from_namespaces | default([]) %}
    # Règle 3+ : trafic intra-cluster pod-à-pod depuis {{ ns }}
    # Cilium ignore ipBlock pour les flux inter-pods — namespaceSelector requis.
    - from:
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: "{{ ns }}"
      ports:
        - protocol: TCP
          port: {{ netpol_api_port }}
{% endfor %}
