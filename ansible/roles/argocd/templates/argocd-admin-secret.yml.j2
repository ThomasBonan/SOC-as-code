# argocd-admin-secret.yml.j2 — Secret admin ArgoCD (bcrypt hash)
# Appliqué UNE SEULE FOIS (create-once pattern).
# Le hash est généré dans configure.yml via password_hash('bcrypt').
apiVersion: v1
kind: Secret
metadata:
  name: argocd-secret
  namespace: "{{ argocd_namespace }}"
  labels:
    app.kubernetes.io/managed-by: soc-ansible
    app.kubernetes.io/part-of: argocd
    soc.lab/component: argocd
type: Opaque
stringData:
  admin.password: "{{ _argocd_admin_password_bcrypt }}"
  admin.passwordMtime: "{{ _argocd_password_mtime }}"
  server.secretkey: "{{ _argocd_server_secretkey }}"
