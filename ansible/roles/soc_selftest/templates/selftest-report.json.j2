{
  "schema_version": "1.0",
  "playbook": "210-soc-selftest",
  "environment": "{{ soc_environment | default('dev') }}",
  "run_id": "{{ _st_run_id }}",
  "timestamp": "{{ _st_timestamp }}",
  "safe_mode": {{ soc_selftest_safe_mode | bool | lower }},
  "inject_via_wazuh": {{ soc_selftest_inject_via_wazuh | bool | lower }},
  "global_status": "{{ _st_global_status }}",
  "phases": {
    "injection":       "{{ _st_inject_status }}",
    "thehive":         "{{ _st_thehive_status }}",
    "cortex":          "{{ _st_cortex_status }}",
    "risk_engine":     "{{ _st_risk_status }}",
    "misp":            "{{ _st_misp_status }}",
    "active_response": "{{ _st_ar_status }}"
  },
  "risk_engine_result": {
    "score":         {{ _st_risk_score | default(-1) }},
    "decision":      "{{ _st_risk_decision | default('unknown') }}",
    "cortex_score":  {{ _st_cortex_score | default(-1) }},
    "thresholds": {
      "auto_close":   {{ soc_risk_thresholds.auto_close }},
      "auto_promote": {{ soc_risk_thresholds.auto_promote }},
      "auto_contain": {{ soc_risk_thresholds.auto_contain }},
      "escalate":     {{ soc_risk_thresholds.escalate }}
    }
  },
  "latency_seconds": {
    "inject_to_thehive": {{ _st_lat_inject_to_thehive | int }},
    "thehive_to_cortex": {{ _st_lat_thehive_to_cortex | int }},
    "cortex_to_risk":    {{ _st_lat_cortex_to_risk    | int }},
    "total":             {{ _st_lat_total              | int }}
  },
  "artifacts": {
    "alert_id": "{{ _st_alert_id | default('') }}",
    "case_id":  "{{ _st_case_id  | default('') }}",
    "misp_event_id": "{{ _st_misp_event_id | default('') }}"
  },
  "test_ioc": {
    "ip":  "{{ soc_selftest_test_ip }}",
    "rfc": "RFC 5737 TEST-NET-3 (non-routable, safe for lab use)",
    "tags": ["{{ soc_selftest_test_tag }}", "run:{{ _st_run_id }}"]
  },
  "meta": {
    "kubeconfig":         "{{ soc_selftest_kubeconfig_path | basename }}",
    "validate_certs":     {{ soc_selftest_validate_certs | bool | lower }},
    "fail_on_error":      {{ soc_selftest_fail_on_error  | bool | lower }},
    "cleanup_enabled":    {{ soc_selftest_cleanup        | bool | lower }},
    "injection_rule_id":  {{ soc_selftest_injection_rule_id }},
    "timeouts": {
      "thehive_s":    {{ soc_selftest_timeout_seconds }},
      "automation_s": {{ soc_selftest_automation_timeout_seconds }},
      "risk_s":       {{ soc_selftest_risk_timeout_seconds }},
      "poll_interval_s": {{ soc_selftest_poll_interval }}
    }
  }
}
