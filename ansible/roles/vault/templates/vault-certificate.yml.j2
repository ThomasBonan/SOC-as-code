# vault-certificate.yml.j2 — Certificate cert-manager pour Vault TLS
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: "{{ vault_certificate_name }}"
  namespace: "{{ vault_namespace }}"
  labels:
    app.kubernetes.io/managed-by: soc-ansible
    soc.lab/component: vault
spec:
  secretName: "{{ vault_tls_secret_name }}"
  duration: 8760h    # 1 an
  renewBefore: 720h  # Renouveler 30j avant expiration
  subject:
    organizations:
      - soc-lab
  isCA: false
  privateKey:
    algorithm: RSA
    size: 2048
  usages:
    - server auth
    - client auth
  dnsNames:
{% for dns in vault_dns_names %}
    - "{{ dns }}"
{% endfor %}
    - "localhost"
  ipAddresses:
    - "127.0.0.1"
  issuerRef:
    name: "{{ vault_cluster_issuer_name }}"
    kind: ClusterIssuer
    group: cert-manager.io
