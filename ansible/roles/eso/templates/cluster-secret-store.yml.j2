# cluster-secret-store.yml.j2 — ClusterSecretStore pointant vers HashiCorp Vault
apiVersion: external-secrets.io/v1beta1
kind: ClusterSecretStore
metadata:
  name: "{{ eso_cluster_secret_store_name }}"
  labels:
    app.kubernetes.io/managed-by: soc-ansible
    soc.lab/component: eso-cluster-secret-store
spec:
  provider:
    vault:
      server: "{{ eso_vault_addr }}"
      path: "{{ eso_vault_kv_mount }}"
      version: "v2"
      caProvider:
        type: ConfigMap
        name: "{{ eso_vault_ca_bundle_secret }}"
        key: ca.crt
        namespace: "{{ eso_namespace }}"
      auth:
        kubernetes:
          mountPath: "{{ eso_vault_k8s_auth_path }}"
          role: "{{ eso_vault_k8s_auth_role }}"
          serviceAccountRef:
            name: external-secrets
            namespace: "{{ eso_namespace }}"
